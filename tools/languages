
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title🌍>学十国外语 · 问好</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --primary: #6c5ce7; --primary2: #a29bfe; --accent: #fd79a8;
  --gold: #fdcb6e; --dark: #2d3436; --light: #dfe6e9;
  --card: #ffffff; --bg: #f0f2f5;
}
body { font-family: -apple-system, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif; background: var(--bg); color: var(--dark); min-height: 100vh; }
.container { max-width: 820px; margin: 0 auto; padding: 20px 16px 60px; }

/* ===== Header ===== */
header { text-align: center; padding: 30px 0 20px; }
h1 { font-size: 2.2em; background: linear-gradient(135deg, var(--primary), var(--accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; letter-spacing: -0.5px; }
.subhead { color: #888; font-size: 0.95em; margin-top: 6px; letter-spacing: 2px; }

/* ===== 标签切换 ===== */
.tabs { display: flex; justify-content: center; gap: 10px; margin: 20px 0 25px; }
.tab { padding: 10px 28px; border-radius: 30px; border: none; font-size: 0.95em; cursor: pointer; font-weight: 600; transition: all 0.2s; background: #fff; color: #999; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
.tab.active { background: var(--primary); color: #fff; box-shadow: 0 4px 15px rgba(108,92,231,0.35); transform: scale(1.02); }
.tab:hover:not(.active) { background: #f5f3ff; color: var(--primary); }

/* ===== 语言卡片 ===== */
.lang-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 18px; }
.lang-card {
  background: var(--card); border-radius: 18px; padding: 24px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06); transition: all 0.25s;
  cursor: pointer; position: relative; overflow: hidden;
  border-left: 5px solid var(--primary);
}
.lang-card:hover { transform: translateY(-3px); box-shadow: 0 8px 25px rgba(0,0,0,0.1); }
.lang-card.expanded { border-left-color: var(--accent); }

.lang-name { font-size: 1.3em; font-weight: 700; display: flex; align-items: center; gap: 10px; }
.lang-name .flag { font-size: 1.1em; }
.lang-name .speakers { font-size: 0.5em; font-weight: 400; color: #999; margin-left: auto; }

.hello-row { margin: 10px 0 6px; display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
.hello-write { font-size: 1.5em; font-weight: 600; color: var(--primary); overflow-wrap: anywhere; }
.hello-romaji { font-size: 0.9em; color: #888; font-style: italic; min-width: 0; }
.hello-phonetic { font-size: 0.85em; color: #aaa; font-family: 'Times New Roman', serif; min-width: 0; }

.play-btn {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 6px 16px; border-radius: 20px; border: none;
  background: var(--primary); color: #fff; font-size: 0.8em;
  cursor: pointer; transition: all 0.2s;
}
.play-btn:hover { background: #5a4bd1; transform: scale(1.05); }
.play-btn:active { transform: scale(0.95); }
.play-btn.playing { background: var(--accent); animation: pulse 0.6s infinite; }
.play-btn.loading { background: #b8b5e0; pointer-events: none; }
.play-btn .src-badge { font-size: 0.6em; background: rgba(255,255,255,0.25); padding: 1px 6px; border-radius: 8px; margin-left: 4px; }
@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.7; } }

.lang-detail {
  max-height: 0; overflow: hidden; transition: max-height 0.4s ease;
  border-top: 0 solid #eee; margin-top: 0;
}
.lang-card.expanded .lang-detail {
  max-height: 400px; border-top-width: 1px; margin-top: 16px; padding-top: 16px;
}
.lang-detail p { font-size: 0.9em; color: #555; line-height: 1.7; margin-bottom: 6px; }
.lang-detail .tag {
  display: inline-block; padding: 2px 10px; border-radius: 12px;
  font-size: 0.75em; margin: 3px 4px 3px 0; font-weight: 500;
}
.tag-family { background: #dfe6e9; color: #555; }
.tag-country { background: #ffeaa7; color: #856404; }
.tag-speakers { background: #74b9ff; color: #fff; }

.voice-status { font-size: 0.7em; display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 10px; margin-left: 8px; }
.voice-status.ok { background: #e6fff8; color: #00b894; }
.voice-status.fallback { background: #fff8e1; color: #f39c12; }

.expand-hint { font-size: 0.75em; color: #ccc; margin-top: 8px; display: flex; align-items: center; gap: 4px; }

/* ===== 考试区 ===== */
.exam-section {
  background: var(--card); border-radius: 20px; padding: 30px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08); margin-top: 10px;
  text-align: center;
}
.exam-progress { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
.exam-progress-bar { flex: 1; height: 6px; background: #eee; border-radius: 3px; margin: 0 15px; overflow: hidden; }
.exam-progress-fill { height: 100%; background: linear-gradient(90deg, var(--primary), var(--accent)); border-radius: 3px; transition: width 0.4s; }
.exam-score { font-weight: 700; color: var(--primary); font-size: 1em; }

.exam-listen-hint { font-size: 0.85em; color: #999; margin-bottom: 10px; }
.exam-play-big {
  width: 80px; height: 80px; border-radius: 50%; border: none;
  background: linear-gradient(135deg, var(--primary), var(--primary2));
  color: #fff; font-size: 2em; cursor: pointer; margin: 10px auto 18px;
  box-shadow: 0 6px 20px rgba(108,92,231,0.3);
  transition: all 0.2s; display: flex; align-items: center; justify-content: center;
}
.exam-play-big:hover { transform: scale(1.08); }
.exam-play-big:active { transform: scale(0.95); }
.exam-play-big.playing { background: var(--accent); box-shadow: 0 6px 20px rgba(253,121,168,0.4); }
.exam-play-big.loading { background: #b8b5e0; animation: pulse 0.6s infinite; }

.exam-question { font-size: 1.1em; color: #555; margin-bottom: 20px; font-weight: 500; }

.exam-options {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 10px;
  margin: 20px 0;
}
.exam-option {
  padding: 14px 18px; border-radius: 14px; border: 2px solid #eee;
  background: #fff; cursor: pointer; transition: all 0.2s;
  font-size: 0.95em; text-align: left; display: flex; align-items: center; gap: 10px;
}
.exam-option:hover:not(.disabled) { border-color: var(--primary2); background: #f8f7ff; }
.exam-option .opt-letter {
  width: 28px; height: 28px; border-radius: 50%; background: #f0f0f0;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 0.8em; color: #888; flex-shrink: 0;
}
.exam-option .opt-write { font-size: 1.2em; font-weight: 600; color: var(--dark); }
.exam-option .opt-lang { font-size: 0.75em; color: #999; margin-top: 2px; }
.exam-option.correct { border-color: #00b894; background: #e6fff8; }
.exam-option.correct .opt-letter { background: #00b894; color: #fff; }
.exam-option.wrong { border-color: #ff7675; background: #fff5f5; }
.exam-option.wrong .opt-letter { background: #ff7675; color: #fff; }
.exam-option.disabled { pointer-events: none; opacity: 0.7; }

.exam-feedback { margin: 15px 0; font-size: 1em; font-weight: 600; min-height: 30px; }
.exam-feedback.correct { color: #00b894; }
.exam-feedback.wrong { color: #ff7675; }

.exam-btn {
  padding: 12px 40px; border-radius: 30px; border: none;
  font-size: 1em; font-weight: 600; cursor: pointer;
  background: var(--primary); color: #fff;
  transition: all 0.2s;
}
.exam-btn:hover { background: #5a4bd1; transform: scale(1.02); }
.exam-btn:disabled { background: #ccc; cursor: not-allowed; transform: none; }
.exam-btn.secondary { background: #f0f0f0; color: #666; }
.exam-btn.secondary:hover { background: #e0e0e0; }

/* ===== 奖状 ===== */
.certificate-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); display: none; align-items: center; justify-content: center;
  z-index: 1000; padding: 20px;
}
.certificate-overlay.show { display: flex; }
.certificate {
  background: #fff; border-radius: 24px; padding: 40px 36px; max-width: 600px;
  width: 100%; text-align: center; position: relative;
  box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  border: 6px double var(--gold);
}
.cert-badge { font-size: 4em; margin-bottom: 10px; }
.cert-title { font-size: 1.8em; font-weight: 800; color: var(--dark); letter-spacing: 2px; }
.cert-subtitle { color: #999; margin: 8px 0 20px; font-size: 0.95em; }
.cert-name { font-size: 1.4em; font-weight: 700; color: var(--primary); margin: 10px 0; padding: 10px 0; border-top: 2px dashed #eee; border-bottom: 2px dashed #eee; }
.cert-langs {
  display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; margin: 18px 0;
}
.cert-lang-tag {
  padding: 4px 14px; border-radius: 20px; background: #f0edff;
  color: var(--primary); font-size: 0.8em; font-weight: 500;
}
.cert-footer { font-size: 0.8em; color: #aaa; margin-top: 20px; line-height: 1.6; }
.cert-seal {
  position: absolute; top: 30px; right: 30px; width: 70px; height: 70px;
  border-radius: 50%; background: var(--accent); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 2em; font-weight: 800; transform: rotate(15deg);
  box-shadow: 0 3px 10px rgba(253,121,168,0.3);
}
.cert-close {
  margin-top: 20px; padding: 12px 40px; border-radius: 30px; border: none;
  background: var(--primary); color: #fff; font-size: 1em; font-weight: 600; cursor: pointer;
}

/* ===== 学习进度 ===== */
.study-progress { display: flex; justify-content: center; gap: 6px; margin-bottom: 20px; }
.study-dot {
  width: 14px; height: 14px; border-radius: 50%; background: #ddd; transition: all 0.3s;
}
.study-dot.done { background: var(--primary); box-shadow: 0 0 8px rgba(108,92,231,0.3); }
.study-dot.current { background: var(--gold); transform: scale(1.3); }

/* ===== 响应式 ===== */
@media (max-width: 600px) {
  .container { padding: 12px; }
  h1 { font-size: 1.6em; }
  .lang-grid { grid-template-columns: 1fr; }
  .exam-options { grid-template-columns: 1fr; }
  .certificate { padding: 28px 20px; }
  .cert-seal { width: 50px; height: 50px; font-size: 1.3em; top: 20px; right: 20px; }
}
</style>
</head>
<body>

<div class="container">
  <header>
    <h1>🌏 学十国外语 · 问好</h1>
    <div class="subhead">一句"你好"走遍全球 — 听说读写 · 一站掌握</div>
  </header>

  <div class="tabs">
    <button class="tab active" onclick="switchTab('learn')">📖 学习</button>
    <button class="tab" onclick="switchTab('exam')">✏️ 考试</button>
  </div>

  <!-- ===== 学习 ===== -->
  <div id="tab-learn">
    <div class="lang-grid" id="langGrid"></div>
  </div>

  <!-- ===== 考试 ===== -->
  <div id="tab-exam" style="display:none;">
    <div class="exam-section">
      <div class="exam-progress">
        <span style="font-weight:600;">🎯 挑战</span>
        <view class="exam-progress-bar">
          <div class="exam-progress-fill" id="examProgressFill" style="width:0%"></div>
        </view>
        <span class="exam-score" id="examScore">0 / 0</span>
      </div>

      <div class="study-progress" id="studyDots"></div>

      <div class="exam-listen-hint">🔊 点击下方按钮，听这段"你好"说的是哪种语言？</div>
      <button class="exam-play-big" id="playBtn" onclick="playExamAudio()">🔊</button>

      <div class="exam-question" id="examQuestion">这段问候语属于哪种语言？</div>

      <div class="exam-options" id="examOptions"></div>

      <div class="exam-feedback" id="examFeedback"></div>

      <div style="display:flex; gap: 10px; justify-content: center; flex-wrap: wrap;">
        <button class="exam-btn" id="nextBtn" onclick="nextQuestion()" disabled>下一题 →</button>
        <button class="exam-btn secondary" onclick="resetExam()">🔄 重新开始</button>
      </div>
    </div>
  </div>
</div>

<!-- ===== 奖状弹窗 ===== -->
<div class="certificate-overlay" id="certOverlay">
  <div class="certificate" id="certContent">
    <div class="cert-seal">🎓</div>
    <div class="cert-badge">🏆</div>
    <div class="cert-title">🌟 十国外语人才</div>
    <div class="cert-subtitle">— 国际问候语能力认证 —</div>
    <div class="cert-name" id="certName">____同学</div>
    <p style="color:#666;font-size:0.9em;margin:10px 0;">
      经考核，已掌握以下<span id="certLangCount"></span>种语言的问候语，<br>
      能够通过听音辨识语言及其文字，达到"十国外语"水平。
    </p>
    <div class="cert-langs" id="certLangs"></div>
    <div style="display:flex; justify-content:space-between; margin-top:15px; font-size:0.75em; color:#aaa;">
      <span>证书编号: HELLO-10-<span id="certNo"></span></span>
      <span>签发日期: <span id="certDate"></span></span>
    </div>
    <div class="cert-footer">🎉 行万里路，从一句"你好"开始。<br>Keep learning, keep exploring!</div>
    <button class="cert-close" onclick="closeCert()">🎊 太棒了！</button>
    <button style="margin-top:10px; background:transparent; color:#999; border:none; font-size:0.8em; cursor:pointer;" onclick="downloadCertImage()">💾 保存奖状</button>
  </div>
</div>

