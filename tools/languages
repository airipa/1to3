// ==================== 考试 ====================
let examState = {
  answered: false,
  currentIndex: 0,
  correctCount: 0,
  questions: [],
  wrongIds: [],  // store question indices for review
};

const LABELS = ['A', 'B', 'C', 'D'];

function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function initExam() {
  // Generate 15 questions (one per language, plus maybe repeats)
  const all = [...LANGUAGES];
  // For variety, use all languages as questions in random order
  const questions = shuffle(all.map((lang, idx) => ({
    langIndex: idx,
    langId: lang.id,
    langName: lang.name,
    flag: lang.flag,
    helloWrite: lang.helloWrite,
    audioLang: lang.audioLang,
    audioText: lang.audioText,
  })));

  examState = {
    answered: false,
    currentIndex: 0,
    correctCount: 0,
    questions,
    wrongIds: [],
  };

  renderDots();
  showQuestion();
}

function renderDots() {
  const container = document.getElementById('studyDots');
  container.innerHTML = examState.questions.map((q, i) => {
    let cls = '';
    if (i < examState.currentIndex) cls = 'done';
    else if (i === examState.currentIndex) cls = 'current';
    return `<span class="study-dot ${cls}"></span>`;
  }).join('');
}

function showQuestion() {
  const q = examState.questions[examState.currentIndex];
  if (!q) { finishExam(); return; }

  examState.answered = false;
  document.getElementById('examFeedback').textContent = '';
  document.getElementById('examFeedback').className = 'exam-feedback';
  document.getElementById('nextBtn').disabled = true;
  document.getElementById('playBtn').className = 'exam-play-big';

  // Build options: 1 correct + 3 random others
  const correctLang = LANGUAGES[q.langIndex];
  const others = LANGUAGES
    .filter((_, i) => i !== q.langIndex)
    .sort(() => Math.random() - 0.5)
    .slice(0, 3);

  const options = shuffle([
    { langIndex: q.langIndex, name: correctLang.name, flag: correctLang.flag, write: correctLang.helloWrite, correct: true },
    ...others.map(l => ({ langIndex: LANGUAGES.indexOf(l), name: l.name, flag: l.flag, write: l.helloWrite, correct: false }))
  ]);

  const container = document.getElementById('examOptions');
  container.innerHTML = options.map((opt, i) => `
    <div class="exam-option" onclick="selectOption(${i})" data-opt-index="${i}" data-correct="${opt.correct}">
      <span class="opt-letter">${LABELS[i]}</span>
      <span>
        <div class="opt-write">${opt.flag} ${opt.write}</div>
        <div class="opt-lang">${opt.name}</div>
      </span>
    </div>
  `).join('');

  document.getElementById('examQuestion').textContent = `🎧 这段问候是哪种语言？（${examState.currentIndex + 1}/${examState.questions.length}）`;
  document.getElementById('examScore').textContent = `${examState.correctCount} / ${examState.questions.length}`;

  // Update progress bar
  const pct = examState.currentIndex / examState.questions.length * 100;
  document.getElementById('examProgressFill').style.width = pct + '%';

  renderDots();

  // Auto play
  setTimeout(() => playExamAudio(), 400);
}

function playExamAudio() {
  const q = examState.questions[examState.currentIndex];
  if (!q) return;
  const lang = LANGUAGES[q.langIndex];

  if (currentAudio) { currentAudio.pause(); currentAudio = null; }
  window.speechSynthesis.cancel();

  const btn = document.getElementById('playBtn');
  btn.className = 'exam-play-big loading';

  const url = getGoogleTTSUrl(lang.googleLang, lang.googleTTS);
  const audio = new Audio(url);
  currentAudio = audio;

  const timeout = setTimeout(() => {
    if (currentAudio === audio) {
      currentAudio = null;
      audio.src = '';
      const utterance = new SpeechSynthesisUtterance(lang.audioText);
      utterance.lang = lang.audioLang;
      utterance.rate = 0.85;
      utterance.onstart = () => { btn.className = 'exam-play-big playing'; };
      utterance.onend = () => { btn.className = 'exam-play-big'; };
      window.speechSynthesis.speak(utterance);
    }
  }, 5000);

  audio.onerror = () => {
    clearTimeout(timeout);
    currentAudio = null;
    // Fallback to SSML
    const utterance = new SpeechSynthesisUtterance(lang.audioText);
    utterance.lang = lang.audioLang;
    utterance.rate = 0.85;
    utterance.onstart = () => { btn.className = 'exam-play-big playing'; };
    utterance.onend = () => { btn.className = 'exam-play-big'; };
    window.speechSynthesis.speak(utterance);
  };

  audio.oncanplaythrough = () => {
    clearTimeout(timeout);
    btn.className = 'exam-play-big playing';
    audio.play().catch(() => {
      btn.className = 'exam-play-big';
    });
  };
  audio.onended = () => {
    clearTimeout(timeout);
    currentAudio = null;
    btn.className = 'exam-play-big';
  };
  audio.load();
}

function selectOption(optIndex) {
  if (examState.answered) return;

  const opts = document.querySelectorAll('.exam-option');
  const selected = opts[optIndex];
  const isCorrect = selected.dataset.correct === 'true';

  examState.answered = true;
  opts.forEach(o => o.classList.add('disabled'));

  const feedback = document.getElementById('examFeedback');

  if (isCorrect) {
    selected.classList.add('correct');
    examState.correctCount++;
    feedback.textContent = '✅ 正确！太棒了！🎉';
    feedback.className = 'exam-feedback correct';
  } else {
    selected.classList.add('wrong');
    // highlight correct answer
    opts.forEach(o => { if (o.dataset.correct === 'true') o.classList.add('correct'); });
    feedback.textContent = '❌ 再听一次，记住它吧！';
    feedback.className = 'exam-feedback wrong';
    examState.wrongIds.push(examState.currentIndex);
  }

  document.getElementById('examScore').textContent = `${examState.correctCount} / ${examState.questions.length}`;
  document.getElementById('nextBtn').disabled = false;
}

function nextQuestion() {
  if (examState.currentIndex < examState.questions.length - 1) {
    examState.currentIndex++;
    showQuestion();
  } else {
    finishExam();
  }
}

function finishExam() {
  const total = examState.questions.length;
  const correct = examState.correctCount;
  const pct = Math.round(correct / total * 100);

  const container = document.getElementById('examOptions');
  container.innerHTML = '';
  document.getElementById('playBtn').style.display = 'none';
  document.getElementById('examQuestion').textContent = '';
  document.querySelector('.exam-listen-hint').style.display = 'none';
  document.getElementById('nextBtn').disabled = true;
  document.getElementById('examProgressFill').style.width = '100%';

  const fb = document.getElementById('examFeedback');

  if (pct >= 80) {
    fb.className = 'exam-feedback correct';
    fb.innerHTML = `🎊 恭喜你！得分 ${correct}/${total}（${pct}%）<br>你已经掌握了十几种语言的问候！<br>🎓 你已是"十国外语人才"！`;

    // Show certificate after a brief delay
    setTimeout(showCertificate, 1200);
  } else {
    fb.className = 'exam-feedback wrong';
    fb.innerHTML = `得分 ${correct}/${total}（${pct}%），再练练吧！<br>💪 80分以上可获得国际问候语认证奖状！`;
    document.getElementById('nextBtn').disabled = false;
    document.getElementById('nextBtn').textContent = '🔄 再试一次';
    document.getElementById('nextBtn').onclick = resetExam;
  }

  renderDots();
}

