// ==================== TTS 语音 — 双引擎 ====================
// 主引擎: Google翻译TTS (覆盖所有语言，发音标准)
// 备选: 浏览器原生SpeechSynthesis (系统有对应语音时优先)

let currentAudio = null;
let speakingLangId = null;
let voiceCache = {};

function getGoogleTTSUrl(langCode, text) {
  return 'https://translate.google.com/translate_tts?ie=UTF-8&q='
    + encodeURIComponent(text)
    + '&tl=' + langCode
    + '&client=tw-ob';
}

function speakViaGoogle(lang, onStart, onEnd, pitchRatio) {
  if (currentAudio) {
    currentAudio.pause();
    currentAudio = null;
  }
  const url = getGoogleTTSUrl(lang.googleLang, lang.googleTTS);
  const audio = new Audio(url);
  currentAudio = audio;

  // Timeout: if Google TTS doesn't load in 5s, fall back to SSML
  const timeout = setTimeout(() => {
    if (currentAudio === audio) {
      audio.src = '';
      currentAudio = null;
      speakViaSSML(lang, onStart, onEnd);
    }
  }, 5000);

  audio.onerror = () => {
    clearTimeout(timeout);
    if (currentAudio === audio) currentAudio = null;
    speakViaSSML(lang, onStart, onEnd);
  };
  audio.oncanplaythrough = () => {
    clearTimeout(timeout);
    if (onStart) onStart();
    audio.play().catch(() => {
      speakViaSSML(lang, onStart, onEnd);
    });
  };
  audio.onended = () => {
    clearTimeout(timeout);
    if (currentAudio === audio) currentAudio = null;
    if (onEnd) onEnd();
  };
  audio.load();
}

function playWithPitchShift(audio, ratio, onEnd) {
  // 用 XMLHttpRequest 获取音频数据 (比 fetch 更兼容跨域)
  const url = audio.src;
  const xhr = new XMLHttpRequest();
  xhr.open('GET', url, true);
  xhr.responseType = 'arraybuffer';
  xhr.onload = function() {
    try {
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      ctx.resume().then(() => {
        ctx.decodeAudioData(xhr.response, function(buffer) {
          const source = ctx.createBufferSource();
          source.buffer = buffer;
          source.playbackRate.value = ratio;
          source.connect(ctx.destination);
          source.start(0);
          source.onended = function() {
            ctx.close();
            currentAudio = null;
            if (onEnd) onEnd();
          };
        }, function() {
          // decode failed, play original
          audio.play();
          audio.onended = function() { currentAudio = null; if (onEnd) onEnd(); };
        });
      }).catch(function() {
        audio.play();
        audio.onended = function() { currentAudio = null; if (onEnd) onEnd(); };
      });
    } catch(e) {
      audio.play();
      audio.onended = function() { currentAudio = null; if (onEnd) onEnd(); };
    }
  };
  xhr.onerror = function() {
    // XHR failed, play original
    audio.play();
    audio.onended = function() { currentAudio = null; if (onEnd) onEnd(); };
  };
  xhr.send();
}

function speakViaSSML(lang, onStart, onEnd) {
  window.speechSynthesis.cancel();
  const utterance = new SpeechSynthesisUtterance(lang.audioText);
  utterance.lang = lang.audioLang;
  utterance.rate = 0.85;
  utterance.pitch = 1.0;
  utterance.onstart = () => { if (onStart) onStart(); };
  utterance.onend = () => { if (onEnd) onEnd(); };
  utterance.onerror = () => { if (onEnd) onEnd(); };
  window.speechSynthesis.speak(utterance);
}

function speakLang(i) {
  const lang = LANGUAGES[i];
  const btn = document.querySelector(`.play-btn[data-i="${i}"]`);
  if (!btn) return;

  // Toggle off if already playing
  if (speakingLangId === i) {
    if (currentAudio) { currentAudio.pause(); currentAudio = null; }
    window.speechSynthesis.cancel();
    document.querySelectorAll('.play-btn').forEach(b => b.classList.remove('playing'));
    speakingLangId = null;
    return;
  }

  // Cancel any current playback
  if (currentAudio) { currentAudio.pause(); currentAudio = null; }
  window.speechSynthesis.cancel();
  document.querySelectorAll('.play-btn').forEach(b => b.classList.remove('playing'));

  const onStart = () => { btn.classList.remove('loading'); btn.classList.add('playing'); speakingLangId = i; };
  const onEnd = () => { btn.classList.remove('playing'); speakingLangId = null; };

  // Try Google TTS first (reliable for all languages)
  btn.classList.add('loading');
  speakViaGoogle(lang, onStart, () => {
    btn.classList.remove('loading');
    onEnd();
  });
}

function speakVariant(langIdx, variantIdx) {
  const lang = LANGUAGES[langIdx];
  const variant = lang.variants[variantIdx];
  if (!variant) return;

  const btn = document.querySelector(`.play-btn[data-lang="${langIdx}"][data-variant="${variantIdx}"]`);
  if (!btn) return;

  // Toggle off if already playing this
  if (speakingLangId === langIdx + '-' + variantIdx) {
    if (currentAudio) { if (currentAudio._ctx) currentAudio._ctx.close(); else currentAudio.pause(); currentAudio = null; }
    window.speechSynthesis.cancel();
    document.querySelectorAll('.play-btn').forEach(b => b.classList.remove('playing'));
    speakingLangId = null;
    return;
  }

  if (currentAudio) { if (currentAudio._ctx) currentAudio._ctx.close(); else currentAudio.pause(); currentAudio = null; }
  window.speechSynthesis.cancel();
  document.querySelectorAll('.play-btn').forEach(b => b.classList.remove('playing'));

  const onStart = () => { btn.classList.remove('loading'); btn.classList.add('playing'); speakingLangId = langIdx + '-' + variantIdx; };
  const onEnd = () => { btn.classList.remove('playing'); speakingLangId = null; };

  btn.classList.add('loading');

  const url = getGoogleTTSUrl(lang.googleLang, variant.text);
  const audio = new Audio(url);
  currentAudio = audio; // will be replaced by {_ctx, _src} if pitch-shift succeeds

  const timeout = setTimeout(() => {
    if (currentAudio === audio) { currentAudio = null; speakViaSSML({ audioText: variant.text, audioLang: lang.audioLang }, onStart, onEnd); }
  }, 5000);

  audio.onerror = () => { clearTimeout(timeout); if (currentAudio === audio) currentAudio = null; speakViaSSML({ audioText: variant.text, audioLang: lang.audioLang }, onStart, onEnd); };

  audio.oncanplaythrough = () => {
    clearTimeout(timeout); btn.classList.remove('loading'); if (onStart) onStart();

    // 一律先 play() — 在用户手势链内，Chrome 允许播放
    audio.play().catch(() => { speakViaSSML({ audioText: variant.text, audioLang: lang.audioLang }, onStart, onEnd); });
    audio.onended = () => { currentAudio = null; if (onEnd) onEnd(); };

    // 男声：额外尝试变声（异步，成不成都已经 play 了）
    if (variant.label.includes('♂')) {
      tryPitchShift(audio, 0.65);
    }
  };
  audio.load();
}

function tryPitchShift(audio, ratio) {
  // 异步变声 — 不阻塞主播放
  try {
    const url = audio.src;
    if (!url) return;
    const xhr = new XMLHttpRequest();
    xhr.open('GET', url, true);
    xhr.responseType = 'arraybuffer';
    xhr.onloadend = function() {
      if (xhr.status === 200 && xhr.response && xhr.response.byteLength > 1000) {
        try {
          const ctx = new (window.AudioContext || window.webkitAudioContext)();
          ctx.resume().then(function() {
            ctx.decodeAudioData(xhr.response, function(buffer) {
              // 把原 audio 切到很小的音量，用变声版替代
              audio.volume = 0.01;
              const source = ctx.createBufferSource();
              source.buffer = buffer;
              source.playbackRate.value = ratio;
              source.connect(ctx.destination);
              source.start(0);
              currentAudio = { _ctx: ctx, _src: source };
              source.onended = function() { ctx.close(); currentAudio = null; };
            }, function() {});
          }).catch(function() {});
        } catch(e) {}
      }
    };
    xhr.send();
  } catch(e) {}
}

