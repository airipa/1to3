function showCertificate() {
  const overlay = document.getElementById('certOverlay');
  overlay.classList.add('show');

  document.getElementById('certName').textContent = '🏅 超级语言学习者';

  const qs = examState.questions;
  document.getElementById('certLangCount').textContent = qs.length;

  // List all languages
  const langsDiv = document.getElementById('certLangs');
  langsDiv.innerHTML = [...new Set(qs.map(q => LANGUAGES[q.langIndex].name))]
    .map(name => `<span class="cert-lang-tag">${name}</span>`).join('');

  document.getElementById('certNo').textContent = String(Date.now()).slice(-8);
  document.getElementById('certDate').textContent = new Date().toLocaleDateString('zh-CN');
}

function closeCert() {
  document.getElementById('certOverlay').classList.remove('show');
}

function downloadCertImage() {
  const cert = document.getElementById('certContent');
  // Use html2canvas approach - but since we can't include library, we'll just screenshot instructions
  alert('💾 截屏保存：请直接截屏（手机/电脑均可），即可保存您的专属奖状！');
}

// ==================== 标签切换 ====================
function switchTab(tab) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelector(`.tab[onclick*="${tab}"]`).classList.add('active');

  document.getElementById('tab-learn').style.display = tab === 'learn' ? 'block' : 'none';
  document.getElementById('tab-exam').style.display = tab === 'exam' ? 'block' : 'none';

  if (tab === 'exam' && examState.questions.length === 0) {
    initExam();
  }
}

function resetExam() {
  document.getElementById('nextBtn').textContent = '下一题 →';
  document.getElementById('nextBtn').onclick = nextQuestion;
  document.getElementById('playBtn').style.display = 'flex';
  initExam();
}

// ==================== 初始化 ====================
renderLangCards();
initExam();
</script>
